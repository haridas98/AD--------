generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  showInHeader Boolean @default(true)
  sortOrder   Int       @default(0)
  createdAt   String    @default("")
  updatedAt   String    @default("")

  projects    Project[]
}

model Location {
  id        String   @id @default(uuid())
  city      String
  state     String?
  country   String   @default("USA")
  isActive  Boolean  @default(true)
  createdAt String   @default("")

  @@unique([city, state])
}

model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  categoryId  String
  locationId  String?
  cityName    String?
  year        Int?
  completedAt String?
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  stylePreset String   @default("default")
  sortOrder   Int      @default(0)
  createdAt   String   @default("")
  updatedAt   String   @default("")
  deletedAt   String?

  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assets      ProjectAsset[]
  assetUsages ProjectAssetUsage[]

  // Dynamic content blocks (JSON string)
  content     String   @default("[]")

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  canonicalUrl   String?

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isPublished])
  @@index([cityName])
  @@index([year])
  @@index([completedAt])
  @@index([deletedAt])
}

model ProjectAsset {
  id               String              @id @default(uuid())
  projectId        String
  kind             String              @default("image")
  storagePath      String
  publicUrl        String
  originalFilename String
  mimeType         String?
  width            Int?
  height           Int?
  durationMs       Int?
  fileSize         Int?
  checksum         String?
  status           String              @default("active")
  includeInAi      Boolean             @default(true)
  sourceType       String              @default("upload")
  sourcePath       String?
  altText          String?
  caption          String?
  sortOrder        Int                 @default(0)
  createdAt        String              @default("")
  updatedAt        String              @default("")

  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  usages           ProjectAssetUsage[]

  @@unique([projectId, storagePath])
  @@index([projectId])
  @@index([kind])
  @@index([checksum])
  @@index([status])
}

model ProjectAssetUsage {
  id              String       @id @default(uuid())
  projectId       String
  assetId         String
  blockId         String?
  slotKey         String?
  usageType       String?
  cropX           Float?
  cropY           Float?
  cropScale       Float?
  focalX          Float?
  focalY          Float?
  aspectRatio     String?
  captionOverride String?
  labelOverride   String?
  sortOrder       Int          @default(0)
  createdAt       String       @default("")
  updatedAt       String       @default("")

  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset           ProjectAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([assetId])
  @@index([blockId])
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String?
  coverImage  String?
  content     String   @default("")
  isPublished Boolean  @default(false)
  publishedAt String?
  createdAt   String   @default("")
  updatedAt   String   @default("")

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // Tags & categories
  tags        String?

  @@index([isPublished])
  @@index([publishedAt])
}
