{
  "mcpServers": {
    "cdacn": {
      "command": "python",
      "args": ["-m", "shadcn@latest"],
      "includeTools": ["safe_tool", "file_reader", "data_processor"],
      "timeout": 30000
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "YOUR_API_KEY"]
    }
  }
}