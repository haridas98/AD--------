{
  "mcpServers": {
    "cdacn": {
      "command": "python",
      "args": [
        "-m",
        "shadcn@latest"
      ],
      "includeTools": [
        "safe_tool",
        "file_reader",
        "data_processor"
      ],
      "timeout": 30000
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "ctx7sk-42b9195b-71af-438a-b8c1-cfb904bbd276"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem"]
    },
    "browser": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-browser"]
    },
    "github": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-github"]
    },
    "code": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-code"]
    },
    "fetch": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-memory"]
    }
  },
  "$version": 3
}